# ═══════════════════════════════════════════════════════════════
# Docker Compose Environment Variables
# Copy to .env and update with your values
# ═══════════════════════════════════════════════════════════════

# ─── ENVIRONMENT ───
# Set to 'production' on the VPS deployment environment.
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── SECURITY ───
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-openssl-rand-hex-32

# ─── DATABASE ───
# LOCAL PostgreSQL connection string for local development
# Example: postgresql://postgres:fundingsathicrm@localhost:5432/fundingsathicrm
DATABASE_URL=postgresql://postgres:fundingsathicrm@localhost:5432/fundingsathicrm

# Docker Compose users should use the service hostname instead:
# DATABASE_URL=postgresql://postgres:fundingsathicrm@postgres:5432/fundingsathicrm

# ─── JWT SETTINGS ───
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS & ALLOWED HOSTS ───
# In production, replace with your actual domain/IP, e.g. http://187.127.149.245
ALLOWED_HOSTS=http://187.127.149.245
FRONTEND_URL=http://187.127.149.245

# ─── EMAIL ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@fundingsathi.com

# ─── API BASE OVERRIDES ───
# In production, this should point to the same origin as the frontend when using Nginx proxying
API_BASE=http://187.127.149.245
