# ═══════════════════════════════════════════════════════════════
# Docker Compose Environment Variables
# Copy to .env and update with your values
# ═══════════════════════════════════════════════════════════════

# ─── ENVIRONMENT ───
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── SECURITY ───
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-openssl-rand-hex-32

# ─── DATABASE ───
# LOCAL PostgreSQL connection string for local development
# Example: postgresql://postgres:fundingsathicrm@localhost:5432/fundingsathicrm
DATABASE_URL=postgresql://postgres:fundingsathicrm@localhost:5432/fundingsathicrm

# Docker Compose users can use the service hostname instead:
# DATABASE_URL=postgresql://crm_user:crm_password@postgres:5432/crm_database

# ─── JWT SETTINGS ───
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS & ALLOWED HOSTS ───
ALLOWED_HOSTS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ─── EMAIL ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@fundingsathi.com

# ─── API BASE OVERRIDES ───
API_BASE=http://localhost:8085
